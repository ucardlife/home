   INIT
   ============================================================= */
function animateCounts(){
  if(matchMedia('(prefers-reduced-motion: reduce)').matches)return;
  document.querySelectorAll('#trackerGrid .tracker-num').forEach(function(el){
    var raw=el.textContent.trim();var mm=raw.match(/^(\D*)([\d,]+)(.*)$/);if(!mm)return;
    var pre=mm[1],suf=mm[3];var target=parseInt(mm[2].replace(/,/g,''),10);if(isNaN(target))return;
    var dur=1100,t0=performance.now();
    function tick(now){var pr=Math.min(1,(now-t0)/dur);var v=Math.round(target*(1-Math.pow(1-pr,3)));el.textContent=pre+v.toLocaleString()+suf;if(pr<1)requestAnimationFrame(tick)}
    requestAnimationFrame(tick);
  });
}
function spawnSparks(){
  var hero=document.querySelector('.hero');if(!hero)return;if(matchMedia('(prefers-reduced-motion: reduce)').matches)return;
  for(var i=0;i<14;i++){var s=document.createElement('div');s.className='hero-spark';var sz=2+Math.random()*5;s.style.width=s.style.height=sz+'px';s.style.left=(Math.random()*100)+'%';s.style.bottom=(Math.random()*60)+'%';s.style.animationDuration=(6+Math.random()*7)+'s';s.style.animationDelay=(-Math.random()*8)+'s';hero.appendChild(s)}
}
function initFancy(){
  spawnSparks();
  var onScroll=function(){var h=document.documentElement;var max=h.scrollHeight-h.clientHeight;var pr=max>0?(h.scrollTop/max)*100:0;var el=document.getElementById('scrollProgress');if(el)el.style.width=pr+'%'};
  window.addEventListener('scroll',onScroll,{passive:true});onScroll();
  var tr=document.querySelector('.savings-tracker');
  if(tr){var done=false;var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting&&!done){done=true;animateCounts()}})},{threshold:.3});io.observe(tr)}
}
function renderHeatmap(){
  var wrap=document.getElementById('mapPins'); if(!wrap)return;
  var HOT={'丝路印象':1,'嘉宴':1,'竹子餐厅':1,'TEACHA':1,'一品捞':1,'金盛大酒店':1,'上海饭店':1,'东北人家铁锅炖':1};
  var FIX={'TEACHA':[50,46],'丝路印象':[43,37],'嘉宴':[59,43],'竹子餐厅':[39,54],'一品捞':[52,58],'金盛大酒店':[24,15],'上海饭店':[66,87],'东北人家铁锅炖':[84,29],'全俄空运':[80,63],'雀跃国际物流':[15,40],'古鲁廖娃公证翻译':[33,69],'美遇·颜究所':[27,75],'OK餐厅':[48,72],'乐意餐厅':[36,62],'MG华人美业':[19,57],'丁丁烘焙坊':[88,41]};
  var lang=currentLang;
  wrap.innerHTML=MERCHANTS.map(function(m,i){
    var pp=FIX[m.nameCn];
    if(!pp){var a=i*2.39996,r=18+(i%4)*8;pp=[Math.max(11,Math.min(89,50+Math.cos(a)*r*1.1)),Math.max(15,Math.min(85,50+Math.sin(a)*r*0.78))];}
    var hot=HOT[m.nameCn]?'hot':'';
    var name=lang==='zh'?m.nameCn:lang==='ru'?m.nameRu:m.nameEn;
    var off=lang==='zh'?'折':lang==='ru'?'скидка':'OFF';
    var link=MERCHANT_LINKS[m.nameCn]||SHOP_HOME;
    return '<div class="map-pin '+hot+'" style="left:'+pp[0]+'%;top:'+pp[1]+'%" onclick="window.open(\''+link+'\',\'_blank\')"><div class="pin-label">\ud83d\udccd '+name+' <b>'+m.discount+off+'</b></div><div class="pin-dot"></div></div>';
  }).join('');
}
document.addEventListener('DOMContentLoaded',function(){
    renderFooter();
    renderAdminStatic();
    // set language
    document.querySelectorAll('.lang-dropdown button').forEach(b=>b.dataset.lag=b.dataset.lang);
    setLanguage(currentLang);
    renderMerchantsFull();

    // Enter key for login
    document.getElementById('memberName')?.addEventListener('keydown',function(e){if(e.key==='Enter')memberLogin()});
    document.getElementById('adminPass')?.addEventListener('keydown',function(e){if(e.key==='Enter')adminLogin()});

    // Close mobile menu on outside click
    document.addEventListener('click',function(e){
        const n=document.getElementById('navLinks'),h=document.getElementById('hamburger');
        if(n.classList.contains('open')&&!n.contains(e.target)&&!h.contains(e.target)) n.classList.remove('open')
    });

    // Add reveal class
    document.querySelectorAll('.benefits-grid, .cases-grid, .faq-list, .pricing-grid, .mcat-grid, .recruit-inner, .tracker-grid').forEach(el=>el.classList.add('reveal'));
    observeReveal();

    // Init card filter UIs
    renderMCat();
    initFancy();
});
</script>


