<!DOCTYPE html>
<html lang="zh-CN"><head><meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="description" content="俄优卡 U Card — 为在俄中国留学生与华人打造的本地生活折扣权益卡，莫斯科 40+ 优质商家专属 VIP 折扣。">
<title data-i18n="html.title">俄优卡 U Card — U卡在手，莫城我有</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Inter+Tight:wght@500;600;700;800;900&family=Noto+Sans+SC:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>

:root {
    /* ===== Brand palette (Russian-flag inspired, kept from source) ===== */
    --cobalt: #0039A6; --cobalt-dark: #00205B; --cobalt-deep:#001640; --cobalt-light: #E3ECF8;
    --gold: #C9A84C; --gold-light: #EBDCA6; --gold-dark: #9C7E2C;
    --red: #D52B1E; --red-hover: #B11A10;
    --white: #FFFFFF; --bg: #F5F7FB; --bg-soft:#EDF1F8;
    --text: #14182B; --text-secondary: #535D74; --text-light: #98A0B4;
    --border: #E5EAF2;
    /* Layered depth shadows */
    --shadow-xs: 0 1px 2px rgba(16,24,48,.05);
    --shadow-sm: 0 2px 10px rgba(16,24,48,.06);
    --shadow-md: 0 10px 34px rgba(0,40,120,.10);
    --shadow-lg: 0 22px 60px rgba(0,40,120,.16);
    --shadow-xl: 0 40px 90px rgba(0,32,91,.24);
    --ring: 0 0 0 4px rgba(0,57,166,.12);
    --radius-sm: 10px; --radius-md: 16px; --radius-lg: 24px; --radius-xl: 30px;
    --font-cn: 'Noto Sans SC','PingFang SC','Microsoft YaHei',sans-serif;
    --font-ru: 'Inter','Noto Sans',-apple-system,'Segoe UI',sans-serif;
    --font-en: 'Inter',-apple-system,system-ui,sans-serif;
    --font-num: 'Inter Tight','Inter',system-ui,sans-serif;
    --max-w: 1200px; --nav-h: 70px;
    --ease: .35s cubic-bezier(.4,0,.2,1);
    --ease-out: .5s cubic-bezier(.16,1,.3,1);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{font-family:var(--font-cn);color:var(--text);background:var(--bg);line-height:1.7;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;padding-top:var(--nav-h);overflow-x:hidden}
body.lang-ru{font-family:var(--font-ru)}
body.lang-en{font-family:var(--font-en)}
a{text-decoration:none;color:inherit}
button{cursor:pointer;font-family:inherit;border:none;background:none;color:inherit}
input,select{font-family:inherit;outline:none}
img{max-width:100%;display:block}
ul{list-style:none}
::selection{background:rgba(0,57,166,.14)}
:focus-visible{outline:2px solid var(--cobalt);outline-offset:2px;border-radius:4px}

/* ===== Page-load entrance ===== */
@keyframes pageIn{from{opacity:0}to{opacity:1}}
body{animation:pageIn .6s ease both}

/* ===== NAVBAR (glass) ===== */
.navbar{position:fixed;top:0;left:0;right:0;height:var(--nav-h);background:rgba(255,255,255,.72);backdrop-filter:saturate(180%) blur(18px);-webkit-backdrop-filter:saturate(180%) blur(18px);border-bottom:1px solid rgba(229,234,242,.8);z-index:1000;display:flex;align-items:center;justify-content:center;transition:var(--ease)}
.navbar-inner{width:100%;max-width:var(--max-w);padding:0 24px;display:flex;align-items:center;justify-content:space-between}
.logo{display:flex;align-items:center;gap:10px;cursor:pointer}
.logo img{height:42px;width:auto;transition:var(--ease)}
.logo:hover img{transform:scale(1.05) rotate(-2deg)}
.logo-text{font-weight:900;font-size:21px;background:linear-gradient(135deg,var(--cobalt),var(--red));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:.5px}
.logo-en{font-family:var(--font-en);font-weight:600;font-size:11px;color:var(--gold-dark);letter-spacing:3px;display:block;margin-top:-2px}
.nav-links{display:flex;align-items:center;gap:2px}
.nav-links a{position:relative;padding:8px 16px;border-radius:var(--radius-sm);font-size:14px;font-weight:600;color:var(--text-secondary);transition:var(--ease)}
.nav-links a:not(.btn-primary-nav)::after{content:'';position:absolute;left:16px;right:16px;bottom:4px;height:2px;border-radius:2px;background:var(--cobalt);transform:scaleX(0);transform-origin:center;transition:var(--ease)}
.nav-links a:hover{color:var(--cobalt)}
.nav-links a.active{color:var(--cobalt)}
.nav-links a.active::after,.nav-links a:hover:not(.btn-primary-nav)::after{transform:scaleX(1)}
.nav-links .btn-primary-nav{background:linear-gradient(135deg,var(--red),#EC4435);color:var(--white)!important;padding:9px 22px;border-radius:var(--radius-sm);font-weight:700;margin-left:10px;box-shadow:0 6px 18px rgba(213,43,30,.28);transition:var(--ease)}
.nav-links .btn-primary-nav::after{display:none}
.nav-links .btn-primary-nav:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 10px 26px rgba(213,43,30,.4)}

/* Language Selector */
.lang-selector{position:relative;margin-left:12px}
.lang-btn{display:flex;align-items:center;gap:6px;padding:7px 13px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;color:var(--text-secondary);border:1px solid var(--border);transition:var(--ease);background:var(--white)}
.lang-btn:hover{border-color:var(--cobalt);color:var(--cobalt);box-shadow:var(--shadow-xs)}
.lang-btn svg{width:18px;height:18px}
.lang-dropdown{position:absolute;top:calc(100% + 8px);right:0;background:var(--white);border:1px solid var(--border);border-radius:var(--radius-md);box-shadow:var(--shadow-lg);min-width:140px;overflow:hidden;display:none;z-index:100;transform-origin:top right;animation:ddIn .22s ease}
@keyframes ddIn{from{opacity:0;transform:translateY(-6px) scale(.96)}to{opacity:1;transform:none}}
.lang-dropdown.open{display:block}
.lang-dropdown button{display:flex;align-items:center;gap:8px;width:100%;padding:11px 16px;font-size:13px;font-weight:600;color:var(--text);text-align:left;transition:var(--ease)}
.lang-dropdown button:hover{background:var(--cobalt-light);color:var(--cobalt)}
.lang-dropdown button.active{background:var(--cobalt);color:var(--white)}
.lang-dropdown button .flag{font-size:16px}
.hamburger{display:none;flex-direction:column;gap:5px;padding:6px;cursor:pointer}
.hamburger span{display:block;width:24px;height:2.5px;background:var(--text);border-radius:2px;transition:var(--ease)}

/* ===== PAGES ===== */
.page{display:none}
.page.active{display:block;animation:pageSlide .5s cubic-bezier(.16,1,.3,1)}
@keyframes pageSlide{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
.section{padding:88px 24px;position:relative}
.section-tag{display:inline-block;background:linear-gradient(135deg,var(--gold-light),#F3E9C8);color:var(--gold-dark);padding:5px 18px;border-radius:30px;font-size:11px;font-weight:800;letter-spacing:2px;font-family:var(--font-en);margin-bottom:14px;box-shadow:inset 0 0 0 1px rgba(156,126,44,.18)}
.section-title{text-align:center;font-size:38px;font-weight:900;color:var(--cobalt-dark);margin-bottom:12px;letter-spacing:-1px;line-height:1.15}
.section-title .gold{background:linear-gradient(135deg,var(--gold),var(--gold-dark));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.section-subtitle{text-align:center;font-size:16px;color:var(--text-secondary);max-width:620px;margin:0 auto 52px;line-height:1.7}
.container{max-width:var(--max-w);margin:0 auto}
.hidden{display:none!important}
.gold-text{color:var(--gold-dark)}

/* ===== Scroll reveal ===== */
.reveal{opacity:0;transform:translateY(34px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal.visible{opacity:1;transform:none}
.reveal.visible > *{animation:staggerUp .7s cubic-bezier(.16,1,.3,1) both}
.reveal.visible > *:nth-child(2){animation-delay:.06s}
.reveal.visible > *:nth-child(3){animation-delay:.12s}
.reveal.visible > *:nth-child(4){animation-delay:.18s}
.reveal.visible > *:nth-child(5){animation-delay:.24s}
.reveal.visible > *:nth-child(6){animation-delay:.3s}
@keyframes staggerUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}

/* ===== BUTTONS ===== */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:14px 32px;border-radius:var(--radius-sm);font-weight:700;font-size:15px;transition:var(--ease);position:relative;overflow:hidden;will-change:transform}
.btn::before{content:'';position:absolute;inset:0;background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.35),transparent 70%);transform:translateX(-120%);transition:transform .6s ease}
.btn:hover::before{transform:translateX(120%)}
.btn-red{background:linear-gradient(135deg,var(--red),#EC4435);color:var(--white);box-shadow:0 8px 22px rgba(213,43,30,.28)}
.btn-red:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 14px 34px rgba(213,43,30,.42)}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--white);box-shadow:0 8px 22px rgba(201,168,76,.3)}
.btn-gold:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 14px 34px rgba(201,168,76,.45)}
.btn-outline{background:var(--white);color:var(--cobalt);box-shadow:inset 0 0 0 2px var(--cobalt)}
.btn-outline:hover{background:var(--cobalt);color:var(--white);transform:translateY(-3px) scale(1.02);box-shadow:0 14px 34px rgba(0,57,166,.3)}
.btn-white-outline{background:rgba(255,255,255,.06);color:var(--white);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.4);backdrop-filter:blur(4px)}
.btn-white-outline:hover{background:rgba(255,255,255,.16);transform:translateY(-3px) scale(1.02)}

/* ===== HERO ===== */
.hero{background:linear-gradient(125deg,#06183F 0%,#0A2E6E 28%,#0039A6 50%,#15275E 74%,#1C0B3C 100%);background-size:200% 200%;animation:bgShift 20s ease infinite;color:var(--white);padding:72px 24px 0;position:relative;overflow:hidden}
@keyframes bgShift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(60% 50% at 78% 18%,rgba(201,168,76,.20),transparent 60%),radial-gradient(50% 45% at 8% 85%,rgba(213,43,30,.16),transparent 60%);pointer-events:none;animation:auroraFloat 14s ease-in-out infinite alternate}
@keyframes auroraFloat{from{transform:translate3d(0,0,0) scale(1)}to{transform:translate3d(-3%,2%,0) scale(1.08)}}
.hero::after{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.06) 1px,transparent 1px);background-size:26px 26px;mask-image:linear-gradient(to bottom,black,transparent 75%);-webkit-mask-image:linear-gradient(to bottom,black,transparent 75%);pointer-events:none;opacity:.5}
.hero-inner{max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:48px;align-items:center;position:relative;z-index:1}
.hero-left{padding:48px 0 72px}
.hero-left>*{animation:heroUp .8s cubic-bezier(.16,1,.3,1) both}
.hero-left>*:nth-child(2){animation-delay:.1s}.hero-left>*:nth-child(3){animation-delay:.18s}.hero-left>*:nth-child(4){animation-delay:.26s}.hero-left>*:nth-child(5){animation-delay:.34s}
@keyframes heroUp{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}
.hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,.14);border:1px solid rgba(201,168,76,.32);padding:7px 18px;border-radius:30px;font-size:12px;font-weight:600;letter-spacing:.5px;margin-bottom:26px;color:var(--gold-light);backdrop-filter:blur(6px)}
.hero h1{font-size:clamp(38px,5vw,58px);font-weight:900;line-height:1.06;margin-bottom:10px;letter-spacing:-1.5px}
.hero h1 .gold{background:linear-gradient(135deg,#F1DE9E,var(--gold));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.hero .slogan{font-size:22px;font-weight:600;opacity:.92;margin-bottom:18px;font-family:var(--font-en);letter-spacing:2px;color:var(--gold-light)}
.hero .desc{font-size:16px;line-height:1.85;opacity:.82;max-width:520px;margin-bottom:34px}
.hero .desc strong{color:var(--gold-light);font-weight:700}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap}
.hero-right{display:flex;justify-content:center;align-items:center;padding-bottom:60px;animation:heroUp 1s cubic-bezier(.16,1,.3,1) .2s both}
.hero-card-stack{position:relative;width:400px;height:380px;display:flex;align-items:center;justify-content:center;cursor:pointer}.hero-card-stack::before{content:'';position:absolute;width:440px;height:440px;background:radial-gradient(circle,rgba(201,168,76,.34),transparent 60%);filter:blur(20px);animation:glowPulse 5s ease-in-out infinite}.hero-card-rear{position:absolute;width:310px;border-radius:16px;box-shadow:0 22px 60px rgba(0,0,0,.42);transform:perspective(1100px) rotateY(-15deg) rotateZ(-8deg) translate(52px,-34px) scale(.9);transition:var(--ease-out);z-index:1;opacity:.97}.hero-card-vertical-front{position:relative;height:340px;width:auto;border-radius:18px;box-shadow:0 32px 74px rgba(0,0,0,.46);transform:perspective(1100px) rotateY(9deg) rotateZ(2deg);transition:var(--ease-out);z-index:3;animation:cardFloat 6s ease-in-out infinite}.hero-card-stack:hover .hero-card-vertical-front{transform:perspective(1100px) rotateY(2deg) rotateZ(0) scale(1.08);box-shadow:0 44px 96px rgba(0,0,0,.52);animation-play-state:paused}.hero-card-stack:hover .hero-card-rear{transform:perspective(1100px) rotateY(-11deg) rotateZ(-10deg) translate(78px,-50px) scale(.98)}.hero-card-fallback{width:250px;height:350px;border-radius:18px;background:linear-gradient(160deg,#0A2E6E,#0039A6 55%,#D52B1E);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:20px;letter-spacing:1px;box-shadow:0 32px 74px rgba(0,0,0,.46);z-index:3;position:relative;text-align:center;padding:20px}

/* ===== TEAM ===== */
.team-dept-title{font-size:22px;font-weight:800;color:var(--cobalt-dark);margin-bottom:26px;padding-bottom:10px;position:relative}
.team-dept-title::after{content:'';position:absolute;left:0;bottom:0;width:56px;height:3px;border-radius:3px;background:linear-gradient(90deg,var(--gold),var(--gold-dark))}
.team-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px}
.team-card{background:var(--white);border-radius:var(--radius-md);padding:32px 24px;box-shadow:var(--shadow-sm);border:1px solid var(--border);text-align:center;transition:var(--ease-out);position:relative;overflow:hidden}
.team-card::before{content:'';position:absolute;inset:0 0 auto 0;height:4px;background:linear-gradient(90deg,var(--cobalt),var(--gold),var(--red));opacity:0;transition:var(--ease)}
.team-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg)}
.team-card:hover::before{opacity:1}
.team-avatar{width:78px;height:78px;border-radius:50%;background:linear-gradient(135deg,var(--cobalt),var(--gold));display:flex;align-items:center;justify-content:center;color:var(--white);font-weight:800;font-size:30px;margin:0 auto 16px;box-shadow:0 8px 20px rgba(0,57,166,.22);font-family:var(--font-en)}
.team-card .t-name{font-size:18px;font-weight:800;margin-bottom:3px}
.team-card .t-role{font-size:13px;color:var(--gold-dark);font-weight:700;margin-bottom:12px}
.team-card .t-bio{font-size:13px;color:var(--text-secondary);line-height:1.7}
.team-card .t-badge{display:inline-block;padding:3px 13px;border-radius:20px;font-size:11px;font-weight:700;margin-bottom:12px;letter-spacing:.5px}
.team-card .t-badge.brand{background:var(--cobalt-light);color:var(--cobalt)}
.team-card .t-badge.market{background:#FFF1E2;color:#C2410C}

/* ===== TRACKER ===== */
.savings-tracker{background:var(--white);border-bottom:1px solid var(--border);padding:56px 24px}
.tracker-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;max-width:var(--max-w);margin:0 auto;text-align:center}
.tracker-item{position:relative}
.tracker-item:not(:last-child)::after{content:'';position:absolute;right:-16px;top:10%;height:80%;width:1px;background:var(--border)}
.tracker-item .tracker-num{font-family:var(--font-num);font-size:clamp(34px,4vw,48px);font-weight:800;background:linear-gradient(135deg,var(--cobalt),var(--gold));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;line-height:1.1;letter-spacing:-1px}
.tracker-item .tracker-label{font-size:15px;color:var(--text);font-weight:600;margin-top:6px}
.tracker-item .tracker-sub{font-size:12.5px;color:var(--text-light);margin-top:2px}

/* ===== BENEFITS ===== */
.benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.benefit-card{background:var(--white);border-radius:var(--radius-md);padding:36px 26px;box-shadow:var(--shadow-sm);transition:var(--ease-out);text-align:center;border:1px solid var(--border);position:relative;overflow:hidden}
.benefit-card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--cobalt),var(--gold));transform:scaleX(0);transform-origin:left;transition:var(--ease-out)}
.benefit-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg)}
.benefit-card:hover::after{transform:scaleX(1)}
.benefit-icon{width:66px;height:66px;border-radius:20px;background:linear-gradient(135deg,var(--cobalt-light),#F1F5FC);display:flex;align-items:center;justify-content:center;margin:0 auto 18px;font-size:30px;transition:var(--ease)}
.benefit-card:hover .benefit-icon{transform:scale(1.1) rotate(-4deg)}
.benefit-card h3{font-size:18px;font-weight:800;margin-bottom:8px}
.benefit-card p{font-size:14px;color:var(--text-secondary);line-height:1.65}
.benefit-card .tag{display:inline-block;background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--white);padding:3px 15px;border-radius:20px;font-size:12px;font-weight:800;margin-top:14px;letter-spacing:.5px}

/* ===== MAP ===== */
.map-section{background:var(--white)}
.map-container{max-width:920px;margin:0 auto;background:linear-gradient(180deg,#EAF1FA,#D7E5F4 55%,#C9DAEE);border-radius:var(--radius-lg);padding:36px;position:relative;overflow:hidden;border:1px solid var(--border);box-shadow:var(--shadow-md);min-height:440px}
.map-container::before{content:'\041C\041E\0421\041A\0412\0410 \00B7 MOSCOW';position:absolute;bottom:18px;right:26px;font-family:var(--font-num);font-size:48px;font-weight:900;color:rgba(0,57,166,.07);letter-spacing:5px;pointer-events:none}
.map-ring{position:absolute;border:1px solid rgba(0,57,166,.10);border-radius:50%;top:50%;left:50%;transform:translate(-50%,-50%)}
.map-ring.r1{width:300px;height:300px}
.map-ring.r2{width:500px;height:500px;animation:ringPulse 6s ease-in-out infinite}
@keyframes ringPulse{0%,100%{opacity:.6}50%{opacity:1}}
.map-pin{position:absolute;display:flex;flex-direction:column;align-items:center;transform:translate(-50%,-100%);transition:var(--ease);z-index:2;cursor:pointer}
.map-pin:hover{z-index:10}
.map-pin .pin-dot{width:18px;height:18px;border-radius:50%;background:var(--red);border:3px solid var(--white);box-shadow:0 2px 10px rgba(213,43,30,.45);transition:var(--ease)}
.map-pin .pin-dot::after{content:'';position:absolute;inset:-6px;border-radius:50%;border:2px solid rgba(213,43,30,.4);animation:pinPing 2s ease-out infinite}
@keyframes pinPing{0%{transform:scale(.6);opacity:.9}100%{transform:scale(1.8);opacity:0}}
.map-pin:hover .pin-dot{transform:scale(1.3)}
.map-pin .pin-label{background:var(--white);padding:5px 13px;border-radius:10px;font-size:12px;font-weight:700;color:var(--cobalt);box-shadow:var(--shadow-sm);margin-bottom:8px;white-space:nowrap;border:1px solid var(--border)}
.map-pin .pin-tag{font-size:10px;color:var(--red);font-weight:700;margin-top:2px}
.map-pin.pin-silkroad{top:38%;left:42%}
.map-pin.pin-jiayan{top:45%;left:58%}
.map-pin.pin-bamboo{top:52%;left:35%}
.map-pin.pin-default{opacity:.5}
.map-pin.pin-default .pin-dot{background:var(--cobalt);width:12px;height:12px}
.map-pin.pin-default .pin-dot::after{display:none}
.map-legend{display:flex;gap:24px;justify-content:center;margin-top:22px;flex-wrap:wrap}
.map-legend-item{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text-secondary)}
.map-legend-item .dot{width:12px;height:12px;border-radius:50%;border:2px solid var(--white);box-shadow:0 1px 4px rgba(0,0,0,.15)}
.map-legend-item .dot.red{background:var(--red)}
.map-legend-item .dot.blue{background:var(--cobalt)}

/* ===== MERCHANT COLLECTION ===== */
.merchant-collection{padding:88px 24px;background:var(--bg)}
.mcat-filters{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin:0 auto 44px;max-width:var(--max-w);align-items:center}
.mcat-btn{padding:9px 20px;border-radius:30px;font-size:13px;font-weight:600;color:var(--text-secondary);background:var(--white);border:1px solid var(--border);transition:var(--ease)}
.mcat-btn:hover{color:var(--cobalt);border-color:var(--cobalt);transform:translateY(-2px)}
.mcat-btn.active{background:linear-gradient(135deg,var(--cobalt),#1351C8);color:var(--white);border-color:transparent;box-shadow:0 6px 16px rgba(0,57,166,.28)}
.mcat-search{flex:1;min-width:200px;max-width:300px;padding:9px 16px;border:1px solid var(--border);border-radius:30px;font-size:13px;background:var(--white);transition:var(--ease)}
.mcat-search:focus{border-color:var(--cobalt);box-shadow:var(--ring)}
.mcat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(265px,1fr));gap:24px;max-width:var(--max-w);margin:0 auto}
.mcat-card{background:var(--white);border-radius:var(--radius-md);overflow:hidden;box-shadow:var(--shadow-sm);border:1px solid var(--border);transition:var(--ease-out);display:flex;flex-direction:column;position:relative;transform-style:preserve-3d}
.mcat-card::after{content:'';position:absolute;inset:0;border-radius:var(--radius-md);box-shadow:inset 0 0 0 1.5px rgba(0,57,166,0);transition:var(--ease);pointer-events:none}
.mcat-card:hover{transform:translateY(-10px);box-shadow:var(--shadow-lg)}
.mcat-card:hover::after{box-shadow:inset 0 0 0 1.5px rgba(0,57,166,.25)}
.mcat-card .vip-tag{position:absolute;top:12px;left:12px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--white);padding:4px 12px;border-radius:20px;font-size:10px;font-weight:800;letter-spacing:1px;z-index:2;box-shadow:0 3px 10px rgba(201,168,76,.4);font-family:var(--font-en)}
.mcat-card .discount-hero{position:absolute;top:12px;right:12px;background:linear-gradient(135deg,var(--red),#EC4435);color:var(--white);width:54px;height:54px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:2;box-shadow:0 6px 16px rgba(213,43,30,.4)}
.mcat-card .discount-hero .d-pct{font-size:17px;font-weight:900;line-height:1;font-family:var(--font-num)}
.mcat-card .discount-hero .d-off{font-size:8px;font-weight:600;opacity:.9}
.mcat-card .mcat-img-wrap{height:158px;background:var(--cobalt-light);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.mcat-card .mcat-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .6s cubic-bezier(.16,1,.3,1)}
.mcat-card:hover .mcat-img-wrap img{transform:scale(1.08)}
.mcat-card .mcat-img-wrap .fallback{font-size:36px;font-weight:800;color:var(--cobalt);position:absolute;font-family:var(--font-cn)}
.mcat-card .mcat-body{padding:18px 18px 20px;flex:1;display:flex;flex-direction:column}
.mcat-card .mcat-body .mcat-name{font-size:16px;font-weight:800}
.mcat-card .mcat-body .mcat-name-ru{font-size:12px;color:var(--text-light);font-family:var(--font-en);margin-bottom:4px}
.mcat-card .mcat-body .mcat-desc{font-size:13px;color:var(--text-secondary);line-height:1.55;margin:6px 0 10px;flex:1}
.mcat-card .mcat-body .mcat-meta{display:flex;gap:16px;font-size:11px;font-weight:600;color:var(--cobalt);background:var(--cobalt-light);padding:3px 10px;border-radius:8px;width:max-content;margin-top:auto}

/* ===== CASE STUDIES ===== */
.case-studies{background:var(--white)}
.cases-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
.case-card{background:linear-gradient(180deg,var(--bg),var(--white));border-radius:var(--radius-md);padding:30px 26px;border:1px solid var(--border);transition:var(--ease-out);position:relative;overflow:hidden}
.case-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-md)}
.case-card .quote-icon{font-size:48px;color:var(--gold);opacity:.25;line-height:.6;font-family:Georgia,serif}
.case-card .case-text{font-size:14px;color:var(--text-secondary);line-height:1.75;margin:8px 0 18px}
.case-card .case-author{display:flex;align-items:center;gap:12px}
.case-card .case-author .avatar{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--cobalt),var(--gold));display:flex;align-items:center;justify-content:center;color:var(--white);font-weight:700;font-size:16px}
.case-card .case-author .info .name{font-size:14px;font-weight:700}
.case-card .case-author .info .school{font-size:12px;color:var(--text-light)}
.case-card .case-saved{position:absolute;top:18px;right:18px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--white);padding:4px 14px;border-radius:20px;font-size:13px;font-weight:800;font-family:var(--font-num)}

/* ===== FAQ ===== */
.faq-section{background:var(--bg)}
.faq-list{max-width:740px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
.faq-item{border:1px solid var(--border);border-radius:var(--radius-md);overflow:hidden;background:var(--white);transition:var(--ease)}
.faq-item.open{box-shadow:var(--shadow-md);border-color:rgba(0,57,166,.2)}
.faq-q{width:100%;padding:19px 24px;display:flex;justify-content:space-between;align-items:center;gap:16px;font-size:15px;font-weight:700;color:var(--text);text-align:left;transition:var(--ease)}
.faq-q:hover{color:var(--cobalt)}
.faq-q .faq-icon{font-size:20px;color:var(--cobalt);transition:var(--ease);flex-shrink:0;font-weight:400}
.faq-item.open .faq-q .faq-icon{transform:rotate(45deg)}
.faq-a{padding:0 24px;max-height:0;overflow:hidden;transition:max-height .4s ease,padding .4s ease;font-size:14px;color:var(--text-secondary);line-height:1.75}
.faq-item.open .faq-a{max-height:340px;padding:0 24px 20px}

/* ===== PRICING ===== */
.pricing-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:32px;max-width:720px;margin:0 auto}
.pricing-card{background:var(--white);border-radius:var(--radius-lg);padding:44px 34px;box-shadow:var(--shadow-sm);border:1px solid var(--border);text-align:center;transition:var(--ease-out);position:relative}
.pricing-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg)}
.pricing-card.featured{border-color:transparent;box-shadow:0 14px 44px rgba(201,168,76,.2);background:linear-gradient(180deg,#FFFDF7,var(--white))}
.pricing-card.featured::after{content:'';position:absolute;inset:0;border-radius:var(--radius-lg);padding:1.5px;background:linear-gradient(135deg,var(--gold),var(--cobalt));-webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none}
.pricing-card.featured::before{content:'\2605 'attr(data-recommend);position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:var(--white);padding:5px 22px;border-radius:20px;font-size:12px;font-weight:800;letter-spacing:1px;box-shadow:0 6px 16px rgba(201,168,76,.4)}
.pricing-card .price{font-family:var(--font-num);font-size:56px;font-weight:900;color:var(--cobalt-dark);line-height:1}
.pricing-card .price .unit{font-size:24px;font-weight:700;vertical-align:super}
.pricing-card .price-label{font-size:15px;color:var(--text-secondary);margin:8px 0 22px;font-weight:600}
.pricing-card .features{text-align:left;margin:22px 0 30px}
.pricing-card .features li{padding:8px 0;font-size:14px;color:var(--text-secondary);display:flex;align-items:flex-start;gap:10px}
.pricing-card .features li::before{content:'\2713';color:var(--white);background:linear-gradient(135deg,var(--gold),var(--gold-dark));width:18px;height:18px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;margin-top:2px}
.pricing-card .btn{width:100%}

/* ===== RECRUIT ===== */
.partner-recruit{background:linear-gradient(135deg,var(--cobalt-deep),var(--cobalt-dark) 60%,#16448F);color:var(--white);padding:88px 24px;position:relative;overflow:hidden}
.partner-recruit::before{content:'';position:absolute;inset:0;background:radial-gradient(50% 60% at 85% 20%,rgba(201,168,76,.18),transparent 60%);pointer-events:none}
.recruit-inner{max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;position:relative;z-index:1}
.recruit-left h2{font-size:36px;font-weight:900;margin-bottom:14px;letter-spacing:-.5px}
.recruit-left p{font-size:15px;opacity:.82;line-height:1.8;margin-bottom:26px}
.recruit-features{display:flex;flex-direction:column;gap:14px;margin-bottom:30px}
.recruit-features li{display:flex;align-items:center;gap:12px;font-size:14.5px;opacity:.9}
.recruit-features li::before{content:'\2713';color:var(--cobalt-dark);background:var(--gold-light);width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0}
.recruit-right{display:grid;gap:20px}
.recruit-card{background:rgba(255,255,255,.07);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.14);border-radius:var(--radius-md);padding:26px;transition:var(--ease-out)}
.recruit-card:hover{background:rgba(255,255,255,.13);transform:translateY(-4px)}
.recruit-card h3{font-size:17px;font-weight:800;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.recruit-card p{font-size:13px;opacity:.78;line-height:1.7}
.recruit-card .tag{display:inline-block;background:rgba(201,168,76,.22);color:var(--gold-light);padding:3px 13px;border-radius:20px;font-size:11px;font-weight:700;margin-top:10px}

/* ===== LOGIN ===== */
.login-page{min-height:calc(100vh - var(--nav-h) - 60px);display:flex;align-items:center;justify-content:center;padding:48px 24px;background:radial-gradient(60% 60% at 50% 0%,var(--cobalt-light),var(--bg))}
.login-card{background:var(--white);border-radius:var(--radius-lg);box-shadow:var(--shadow-xl);padding:48px 40px;max-width:448px;width:100%;border:1px solid var(--border)}
.login-card h2{font-size:26px;font-weight:900;text-align:center;color:var(--cobalt-dark)}
.login-card .login-sub{text-align:center;color:var(--text-secondary);font-size:14px;margin-bottom:28px}
.login-tabs{display:flex;margin-bottom:24px;border-radius:var(--radius-sm);overflow:hidden;border:1px solid var(--border);background:var(--bg)}
.login-tab{flex:1;padding:12px;font-size:14px;font-weight:700;color:var(--text-secondary);transition:var(--ease);text-align:center}
.login-tab.active{background:linear-gradient(135deg,var(--cobalt),#1351C8);color:var(--white)}
.form-group{margin-bottom:18px}
.form-group label{display:block;font-size:13px;font-weight:700;color:var(--text);margin-bottom:7px}
.form-group input{width:100%;padding:13px 16px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:14px;transition:var(--ease);background:var(--bg)}
.form-group input:focus{border-color:var(--cobalt);box-shadow:var(--ring);background:var(--white)}
.login-card .btn{width:100%;padding:14px}
.login-footer{text-align:center;margin-top:22px;font-size:14px;color:var(--text-secondary)}
.login-footer a{color:var(--cobalt);font-weight:700}
.login-error{background:#FFF0EF;color:var(--red);padding:11px 16px;border-radius:var(--radius-sm);font-size:14px;margin-bottom:16px;display:none}
.login-error.show{display:block;animation:shake .4s}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}

/* ===== MEMBER ===== */
.member-page{padding:48px 24px 64px}
.member-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;margin-bottom:34px}
.member-header .greeting h2{font-size:27px;font-weight:900;color:var(--cobalt-dark)}
.member-header .greeting p{font-size:14px;color:var(--text-secondary)}
.btn-logout{padding:9px 20px;border-radius:var(--radius-sm);border:1px solid var(--border);color:var(--text-secondary);font-size:14px;font-weight:600;transition:var(--ease)}
.btn-logout:hover{border-color:var(--red);color:var(--red)}
.digital-card-wrap{max-width:540px;margin-bottom:34px}
.digital-card{background:linear-gradient(140deg,var(--cobalt-deep),var(--cobalt) 55%,#1A56A8);border-radius:var(--radius-lg);padding:34px 30px;color:var(--white);box-shadow:var(--shadow-xl);position:relative;overflow:hidden}
.digital-card::before{content:'U CARD';position:absolute;top:-18px;right:-8px;font-size:78px;font-weight:900;opacity:.07;font-family:var(--font-num);letter-spacing:4px}
.digital-card::after{content:'';position:absolute;inset:0;background:radial-gradient(40% 60% at 90% 10%,rgba(201,168,76,.25),transparent 60%);pointer-events:none}
.digital-card .card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:26px;position:relative;z-index:1}
.digital-card .card-brand{font-size:21px;font-weight:800;letter-spacing:1px}
.digital-card .card-type{background:rgba(201,168,76,.24);color:var(--gold-light);padding:5px 14px;border-radius:20px;font-size:12px;font-weight:700}
.digital-card .card-number{font-family:var(--font-num);font-size:23px;letter-spacing:4px;margin-bottom:18px;opacity:.92;position:relative;z-index:1}
.digital-card .card-holder{display:flex;justify-content:space-between;align-items:flex-end;position:relative;z-index:1}
.digital-card .card-holder .field{font-size:11px;opacity:.55;margin-bottom:2px}
.digital-card .card-holder .value{font-size:15px;font-weight:700}
.digital-card .card-qr{position:absolute;bottom:24px;right:24px;width:54px;height:54px;background:var(--white);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--text-light);z-index:1}
.member-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:34px}
.ms-card{background:var(--white);border-radius:var(--radius-md);padding:26px;box-shadow:var(--shadow-sm);border:1px solid var(--border);text-align:center;transition:var(--ease)}
.ms-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md)}
.ms-card .ms-num{font-family:var(--font-num);font-size:34px;font-weight:800;background:linear-gradient(135deg,var(--cobalt),var(--gold));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.ms-card .ms-label{font-size:14px;color:var(--text-secondary);margin-top:4px}
.usage-section h3{font-size:18px;font-weight:800;margin-bottom:16px}
.usage-list{background:var(--white);border-radius:var(--radius-md);border:1px solid var(--border);overflow:hidden}
.usage-item{padding:15px 20px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);font-size:14px}
.usage-item:last-child{border-bottom:none}
.usage-item .shop{font-weight:600}
.usage-item .saved{color:var(--red);font-weight:800;font-family:var(--font-num)}
.usage-item .date{color:var(--text-light);font-size:12px}
.referral-box{background:linear-gradient(135deg,var(--cobalt-light),#F1F5FC);border-radius:var(--radius-md);border:1px solid var(--border);padding:26px;margin-top:24px}
.referral-box h3{font-size:18px;font-weight:800;margin-bottom:12px}
.ref-link{display:flex;gap:8px;align-items:center}
.ref-link input{flex:1;padding:11px 14px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:13px;background:var(--white);color:var(--text-secondary)}
.ref-link button{padding:11px 20px;background:linear-gradient(135deg,var(--cobalt),#1351C8);color:var(--white);border-radius:var(--radius-sm);font-weight:700;font-size:14px;white-space:nowrap;transition:var(--ease)}
.ref-link button:hover{transform:translateY(-2px);box-shadow:0 8px 18px rgba(0,57,166,.3)}

/* ===== ADMIN ===== */
.admin-page{padding:48px 24px 64px}
.admin-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:34px}
.admin-header h2{font-size:27px;font-weight:900;color:var(--cobalt-dark)}
.admin-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:34px}
.admin-stat-card{background:var(--white);border-radius:var(--radius-md);padding:26px;box-shadow:var(--shadow-sm);border:1px solid var(--border);transition:var(--ease)}
.admin-stat-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md)}
.admin-stat-card .asc-label{font-size:14px;color:var(--text-secondary);margin-bottom:4px}
.admin-stat-card .asc-num{font-family:var(--font-num);font-size:38px;font-weight:800;color:var(--cobalt-dark)}
.admin-stat-card .asc-change{font-size:13px;color:#1A9E73;margin-top:4px;font-weight:600}
.chart-section{background:var(--white);border-radius:var(--radius-md);border:1px solid var(--border);padding:26px;margin-bottom:34px}
.chart-section h3{font-size:16px;font-weight:800;margin-bottom:22px}
.bar-chart{display:flex;align-items:flex-end;gap:12px;height:180px;padding:0 8px}
.bar-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px}
.bar-item .bar{width:100%;max-width:42px;background:linear-gradient(180deg,var(--cobalt),var(--gold));border-radius:6px 6px 0 0;min-height:4px;transition:var(--ease-out)}
.bar-item .bar:hover{filter:brightness(1.1)}
.bar-item .bar-label{font-size:11px;color:var(--text-light)}
.bar-item .bar-value{font-size:11px;font-weight:700;color:var(--text-secondary);font-family:var(--font-num)}
.admin-search{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;align-items:center}
.admin-search input,.admin-search select{padding:11px 14px;border:1px solid var(--border);border-radius:var(--radius-sm);font-size:14px;background:var(--white)}
.admin-search input{flex:1;min-width:180px}
.admin-search input:focus{border-color:var(--cobalt);box-shadow:var(--ring)}
.admin-table-wrap{background:var(--white);border-radius:var(--radius-md);border:1px solid var(--border);overflow-x:auto}
.admin-table{width:100%;border-collapse:collapse;font-size:14px}
.admin-table th{background:var(--bg);padding:13px 16px;text-align:left;font-weight:700;color:var(--text-secondary);border-bottom:1px solid var(--border);white-space:nowrap}
.admin-table td{padding:13px 16px;border-bottom:1px solid var(--border);color:var(--text)}
.admin-table tr:last-child td{border-bottom:none}
.admin-table tr:hover td{background:var(--cobalt-light)}
.status-badge{display:inline-block;padding:3px 12px;border-radius:20px;font-size:12px;font-weight:700}
.status-badge.active{background:#E6F6EF;color:#1A9E73}
.status-badge.expired{background:#FFF0EF;color:var(--red)}

/* ===== FOOTER ===== */
.footer{background:linear-gradient(180deg,var(--cobalt-dark),var(--cobalt-deep));color:rgba(255,255,255,.66);padding:56px 24px;text-align:center}
.footer .f-brand{font-size:24px;font-weight:900;color:var(--white);margin-bottom:6px}
.footer .f-brand span{background:linear-gradient(135deg,var(--gold-light),var(--gold));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.footer p{font-size:14px;line-height:1.85;max-width:620px;margin:0 auto}
.footer .f-links{display:flex;justify-content:center;gap:26px;margin-top:22px;flex-wrap:wrap}
.footer .f-links a{color:rgba(255,255,255,.55);font-size:13px;font-weight:500;transition:var(--ease)}
.footer .f-links a:hover{color:var(--gold-light)}

/* ===== TOAST ===== */
.toast{position:fixed;bottom:40px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--cobalt-dark);color:var(--white);padding:14px 28px;border-radius:var(--radius-sm);font-size:14px;font-weight:600;opacity:0;transition:all .45s cubic-bezier(.16,1,.3,1);z-index:2000;pointer-events:none;box-shadow:var(--shadow-lg)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ===== RESPONSIVE (mobile-first refinements) ===== */
@media(max-width:1024px){
    .hero-inner{grid-template-columns:1fr;text-align:center}
    .hero-left{padding:32px 0 48px}
    .hero .desc{margin:0 auto 32px}
    .hero-actions{justify-content:center}
    .hero-card-vertical-front{height:280px;transform:none;animation:none}
    .hero-card-stack{width:320px;height:320px;margin:0 auto}
    .hero-card-rear{transform:perspective(1000px) rotateZ(-8deg) translate(40px,-24px) scale(.86)}
    .hero-right{padding-bottom:48px}
    .benefits-grid,.cases-grid{grid-template-columns:repeat(2,1fr)}
    .recruit-inner{grid-template-columns:1fr;gap:36px}
    .tracker-item:not(:last-child)::after{display:none}
}
@media(max-width:768px){
    .nav-links{position:fixed;top:var(--nav-h);left:0;right:0;background:rgba(255,255,255,.98);backdrop-filter:blur(18px);flex-direction:column;padding:16px 24px;border-bottom:1px solid var(--border);box-shadow:var(--shadow-md);transform:translateY(-130%);opacity:0;transition:var(--ease);pointer-events:none;z-index:99}
    .nav-links.open{transform:translateY(0);opacity:1;pointer-events:auto}
    .nav-links a{width:100%;padding:13px 16px;font-size:15px}
    .nav-links a:not(.btn-primary-nav)::after{display:none}
    .nav-links .btn-primary-nav{margin-left:0;text-align:center}
    .lang-selector{margin-left:0;margin-top:8px}
    .lang-dropdown{right:auto;left:0}
